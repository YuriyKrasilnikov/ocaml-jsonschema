license: "ISC"
homepage: "https://github.com/YuriyKrasilnikov/ocaml-jsonschema"
bug-reports: "https://github.com/YuriyKrasilnikov/ocaml-jsonschema/issues"
depends: [
  "dune" {>= "3.17"}
  "ocaml" {>= "5.1"}
  "yojson" {>= "2.0"}
  "uri" {>= "4.0"}
  "re" {>= "1.10"}
  "alcotest" {with-test}
  "odoc" {with-doc}
]
build: [
  ["dune" "subst"] {dev}
